# 忽略数据集和输出结果 (去掉斜杠，同时兼容文件夹和软链接)
data
output
outputs
# 忽略模型权重
checkpoints
*.pth
*.pt
*.ckpt

# 忽略 Python 缓存
__pycache__/
*.pyc

# 忽略系统文件
.DS_Store

# 忽略环境配置 (如果你在本地创建了 venv 或 conda 环境目录)
venv/
env/
.env

# 忽略 IDE 和编辑器配置文件 (非常重要，否则团队成员的 IDE 配置会冲突)
.vscode/
.idea/
*.swp
*.swo

# 忽略日志文件
*.log

# 忽略数据备份或临时数据
*.tmp
*.bak
data_processed/  # 如果你有处理后的中间数据集